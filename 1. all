        String s, t = "";
        Scanner in = new Scanner(System.in);
        
        System.out.print("Enter a string: ");
        s = in.nextLine();
        
        int length = s.length();
        for (int i = length - 1; i >= 0; i--) {
            t = t + s.charAt(i);
        }
        
        System.out.println("Original: " + s);
        System.out.println("Reverse: " + t);
        
        in.close();
    }
}

